{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "unicorn"],
  "env": {
    "browser": true,
    "es2024": true,
    "node": true
  },
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "typescript/no-unused-vars": "error",
    "no-unused-vars": "off"
  },
  "ignorePatterns": [
    "**/build/**",
    "**/dist/**",
    "**/node_modules/**",
    "**/public/prerendered/**",
    "packages/api/src/_generated/**"
  ]
}
