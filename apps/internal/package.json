{
  "name": "@apps/internal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,sidecar -c cyan,magenta \"vite\" \"npm run sidecar\"",
    "dev:web": "vite",
    "sidecar": "tsx watch server/index.ts",
    "build": "npm run type-check && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint src server --ext .ts,.tsx,.js --max-warnings=0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.66.11",
    "archiver": "^7.0.1",
    "axios": "^1.3.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.9",
    "@types/archiver": "^6.0.3",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^18.19.78",
    "@types/react": "^18.0.29",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "express": "^5.1.0",
    "multer": "^2.0.0",
    "tailwindcss": "^4.0.9",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
